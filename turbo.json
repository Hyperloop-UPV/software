{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "bin/**", "target/release/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "GOCONFIG",
        "GOCACHE",
        "GOPATH",
        "GOROOT",
        "LocalAppData",
        "PATH",
        "USERPROFILE"
      ]
    },
    "dev:main": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": [
        "GOCONFIG",
        "GOCACHE",
        "GOPATH",
        "GOROOT",
        "LocalAppData",
        "PATH",
        "USERPROFILE"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "preview": {
      "dependsOn": ["^preview"]
    }
  }
}
