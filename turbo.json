{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "bin/**", "target/release/**"]
    },
    "blcu-programming#build": {
      "dependsOn": [],
      "outputs": ["../electron-app/binaries/blcu-programming-*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "GOCONFIG",
        "GOCACHE",
        "GOPATH",
        "GOROOT",
        "LocalAppData",
        "PATH",
        "USERPROFILE"
      ]
    },
    "dev:main": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": [
        "GOCONFIG",
        "GOCACHE",
        "GOPATH",
        "GOROOT",
        "LocalAppData",
        "PATH",
        "USERPROFILE"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "preview": {
      "dependsOn": ["^preview"]
    },
    "test": {
      "dependsOn": ["^test"],
      "env": ["GOCACHE", "LocalAppData", "GOPATH"]
    }
  }
}
